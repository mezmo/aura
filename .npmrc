# Lockfile generation is required. npm install must always write and
# respect package-lock.json so the dependency tree stays pinned to exact,
# integrity-checked versions. This file previously set package-lock=false,
# which silently re-resolved the floating ^ ranges on every install --
# the window through which a compromised transitive dependency can enter.
# Keep this setting explicitly true so any future attempt to disable
# lockfile generation is a visible, deliberate edit rather than a silent
# regression.
package-lock=true
