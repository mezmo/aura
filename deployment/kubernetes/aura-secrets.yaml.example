# Example Secret manifest for aura
# This file is a template - SRE/DevOps must create actual secrets per environment
# DO NOT commit actual secret values to git

apiVersion: v1
kind: Secret
metadata:
  name: aura-secrets
  namespace: aura
  labels:
    app: aura
type: Opaque
stringData:
  # OpenAI API Key (primary LLM provider)
  openai_api_key: "sk-proj-..."

  # Anthropic API Key (alternative LLM provider)
  anthropic_api_key: "sk-ant-..."

  # Mezmo API Key (for MCP server authentication)
  # Format: sts_<token> or Bearer token
  mezmo_api_key: "sts_..."

  # AWS Credentials (for Bedrock LLM or other AWS services)
  aws_access_key_id: "AKIA..."
  aws_secret_access_key: "..."
  aws_region: "us-east-1"

---
# Instructions for SRE/DevOps:
#
# 1. Copy this file and remove the .example extension
# 2. Replace placeholder values with actual secrets from vault/secret management
# 3. Apply to the cluster: kubectl apply -f aura-secrets.yaml
# 4. Verify secret exists: kubectl get secret aura-secrets -n aura
#
# Environment-specific notes:
# - Dev: Use dev-specific API keys with limited permissions
# - Int: Use integration testing keys
# - Prod: Use production keys with appropriate monitoring
#
# Security best practices:
# - Never commit actual secret values to git
# - Rotate keys regularly
# - Use separate keys per environment
# - Monitor API usage for anomalies
