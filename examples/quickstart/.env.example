# Copy this file to .env and fill in your provider, model, and API key.
#
#   cp .env.example .env

# ── LLM Provider ────────────────────────────────────────────────────
# Set these three values for your chosen provider.

LLM_PROVIDER=openai
LLM_MODEL=gpt-5.2
LLM_API_KEY=sk-...

# Provider examples (uncomment one group):
#
#   OpenAI (default):
#     LLM_PROVIDER=openai
#     LLM_MODEL=gpt-5.2
#     LLM_API_KEY=sk-...
#
#   Anthropic:
#     LLM_PROVIDER=anthropic
#     LLM_MODEL=claude-sonnet-4-20250514
#     LLM_API_KEY=sk-ant-...
#
#   Ollama (local, no API key needed):
#     LLM_PROVIDER=ollama
#     LLM_MODEL=llama3.1
#     LLM_API_KEY=unused
#     LLM_BASE_URL=http://host.docker.internal:11434

# Optional: base URL override (required for Ollama)
# LLM_BASE_URL=

# Optional: Mezmo MCP server
# MEZMO_API_KEY=...
