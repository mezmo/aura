# test.env
# Environment variables for integration tests
#
# NOTE: OPENAI_API_KEY must be provided externally (not committed to repo)
# - CI: Injected via Jenkins withCredentials
# - Local: Set in shell or use .env.local (gitignored)
#
# Usage:
#   export OPENAI_API_KEY=your-key
#   docker compose -f compose/base.yml -f compose/test.yml up

# OpenAI API key is required but should NOT be in this file
# Uncomment for local testing only (never commit with real key):
# OPENAI_API_KEY=your-key-here

# Test configuration overrides (if needed)
# These are defaults - override via environment or docker-compose
