# Copy this file to .env and fill in your provider, model, and API key.
#
#   cp .env.example .env

# ── LLM Provider ────────────────────────────────────────────────────
# Set these three values for your chosen provider.

LLM_PROVIDER=openai
LLM_MODEL=gpt-5.2
LLM_API_KEY=sk-...

# Provider examples (uncomment one group):
#
#   OpenAI (default):
#     LLM_PROVIDER=openai
#     LLM_MODEL=gpt-5.2
#     LLM_API_KEY=sk-...
#
#   Anthropic:
#     LLM_PROVIDER=anthropic
#     LLM_MODEL=claude-sonnet-4-20250514
#     LLM_API_KEY=sk-ant-...
#
#   Ollama (local, no API key needed):
#     LLM_PROVIDER=ollama
#     LLM_MODEL=llama3.1
#     LLM_API_KEY=unused
#     LLM_BASE_URL=http://host.docker.internal:11434
#
#   llama-server / llama.cpp (local, OpenAI-compatible):
#     LLM_PROVIDER=openai
#     LLM_MODEL=local-model
#     LLM_API_KEY=unused
#     LLM_BASE_URL=http://host.docker.internal:8080/v1

# Optional: base URL override (required for Ollama and llama-server)
# LLM_BASE_URL=

# ── Provider-Specific API Keys ──────────────────────────────────────
# The LLM_API_KEY above is used by quickstart.toml. The example configs
# in examples/ reference provider-specific env vars instead. Set these
# if you plan to serve configs from examples/minimal/ or examples/complete/.
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# ── Optional: MCP Server Keys ───────────────────────────────────────
# MEZMO_API_KEY=...
# GITHUB_PERSONAL_ACCESS_TOKEN=...
# PAGERDUTY_API_TOKEN=...
# DD_API_KEY=...
# DD_APPLICATION_KEY=...
