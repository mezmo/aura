# Environment Variables for Rig TOML POC
# Copy this file to .env and fill in your actual values

# ==========================================
# LLM Provider Configuration
# ==========================================

# OpenAI API Key - Required for LLM and Embeddings
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# MCP Server Configuration
# ==========================================

# Mezmo MCP Server - Log Analysis and Monitoring
# Get your API key from your Mezmo dashboard
MEZMO_API_KEY=your_mezmo_api_key_here

# AWS Bedrock Knowledge Base MCP Server
# Configure your AWS credentials for Bedrock access
AWS_PROFILE=your_aws_profile_name
AWS_REGION=us-east-1

# ==========================================
# Optional: Alternative LLM Providers
# ==========================================

# If using Anthropic instead of OpenAI, set this:
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# Streaming Configuration
# ==========================================

# Tool result streaming mode: none, open-web-ui, or aura
# - none: Spec-compliant, tool results not streamed
# - open-web-ui: Results streamed via tool_calls hack for OpenWebUI
# - aura: Results streamed via aura.tool_complete events
TOOL_RESULT_MODE=aura

# Max characters for tool results in aura.tool_complete events (0 = no truncation)
TOOL_RESULT_MAX_LENGTH=0

# Enable custom aura.* SSE events (tool_start, tool_complete, progress)
AURA_CUSTOM_EVENTS=true

# Enable aura.reasoning events for LLM reasoning/thinking content
AURA_EMIT_REASONING=true

# ==========================================
# How to Use This File
# ==========================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env with your actual API keys
#
# 3. Test the configuration:
#    cargo run -p rig-toml-cli -- --config config.toml --query "Hello, how are you?"
